<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Helvetica Neue', Arial, sans-serif; color: #1a1a2e; background: #fff; }
    .accent-bar { height: 6px; background: linear-gradient(90deg, #4f46e5, #818cf8); }
    .container { max-width: 780px; margin: 0 auto; padding: 48px 40px; }
    .header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 40px; }
    .brand { font-size: 22px; font-weight: 700; color: #4f46e5; }
    .brand-sub { font-size: 12px; color: #6b7280; margin-top: 2px; }
    .invoice-meta { text-align: right; }
    .doc-label { background: #eef2ff; color: #4f46e5; font-size: 11px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; padding: 6px 12px; border-radius: 4px; display: inline-block; margin-bottom: 8px; }
    .invoice-number { font-size: 20px; font-weight: 700; color: #111827; }
    .dates { font-size: 12px; color: #6b7280; margin-top: 4px; line-height: 1.8; }
    .parties { display: flex; justify-content: space-between; margin-bottom: 36px; }
    .party h4 { font-size: 10px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; color: #9ca3af; margin-bottom: 8px; }
    .party p { font-size: 13px; color: #374151; line-height: 1.7; }
    .divider { height: 1px; background: #e5e7eb; margin: 28px 0; }
    .items-table { width: 100%; border-collapse: collapse; }
    .items-table th { font-size: 10px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; color: #9ca3af; padding: 10px 12px; background: #f9fafb; border-bottom: 2px solid #e5e7eb; text-align: left; }
    .items-table th:nth-child(2), .items-table th:nth-child(3), .items-table th:nth-child(4) { text-align: right; }
    .items-table td { font-size: 14px; color: #374151; padding: 14px 12px; border-bottom: 1px solid #f3f4f6; }
    .items-table td:nth-child(2), .items-table td:nth-child(3), .items-table td:nth-child(4) { text-align: right; }
    .items-table tr:last-child td { border-bottom: none; }
    .totals { margin-top: 20px; display: flex; justify-content: flex-end; }
    .totals-inner { width: 280px; }
    .total-line { display: flex; justify-content: space-between; font-size: 14px; color: #374151; padding: 7px 0; }
    .total-line.grand { border-top: 2px solid #4f46e5; margin-top: 8px; padding-top: 14px; font-size: 18px; font-weight: 700; color: #4f46e5; }
    .payment-box { background: #f9fafb; border-radius: 8px; padding: 16px 20px; margin-top: 32px; }
    .payment-box h4 { font-size: 10px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; color: #9ca3af; margin-bottom: 8px; }
    .payment-box p { font-size: 13px; color: #374151; line-height: 1.8; white-space: pre-line; }
    .footer { margin-top: 40px; padding-top: 20px; border-top: 1px solid #e5e7eb; display: flex; justify-content: space-between; font-size: 11px; color: #9ca3af; }
  </style>
</head>
<body>
  <div class="accent-bar"></div>
  <div class="container">
    <div class="header">
      <div>
        <div class="brand">{{freelancer.company}}</div>
        <div class="brand-sub">{{freelancer.email}} · {{freelancer.phone}}</div>
        <div style="font-size:12px;color:#6b7280;margin-top:4px;">{{freelancer.address}}</div>
      </div>
      <div class="invoice-meta">
        <div class="doc-label">Invoice</div>
        <div class="invoice-number">{{invoiceNumber}}</div>
        <div class="dates">
          Issued: {{issueDate}}<br />
          Due: {{dueDate}}
        </div>
      </div>
    </div>

    <div class="parties">
      <div class="party">
        <h4>Bill To</h4>
        <p><strong>{{client.name}}</strong><br />{{client.company}}<br />{{client.address}}<br />{{client.email}}</p>
      </div>
      <div class="party" style="text-align:right">
        <h4>For Project</h4>
        <p><strong>{{project.name}}</strong></p>
      </div>
    </div>

    <table class="items-table">
      <thead>
        <tr>
          <th>Description</th>
          <th>Qty</th>
          <th>Unit Price</th>
          <th>Total</th>
        </tr>
      </thead>
      <tbody>
        {{#each items}}
        <tr>
          <td>{{description}}</td>
          <td>{{quantity}}</td>
          <td>{{unitPrice}}</td>
          <td>{{total}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>

    <div class="totals">
      <div class="totals-inner">
        <div class="total-line"><span>Subtotal</span><span>{{subtotal}}</span></div>
        <div class="total-line"><span>Tax ({{taxRate}})</span><span>{{tax}}</span></div>
        <div class="total-line grand"><span>Total Due</span><span>{{grandTotal}}</span></div>
      </div>
    </div>

    <div class="payment-box">
      <h4>Payment Instructions</h4>
      <p>{{paymentInstructions}}</p>
    </div>

    <div class="footer">
      <span>{{freelancer.company}} · {{invoiceNumber}}</span>
      <span>Thank you for your business!</span>
    </div>
  </div>
</body>
</html>
