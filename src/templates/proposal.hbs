<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Helvetica Neue', Arial, sans-serif; color: #1a1a2e; background: #fff; }
    .accent-bar { height: 6px; background: linear-gradient(90deg, #4f46e5, #818cf8); }
    .container { max-width: 780px; margin: 0 auto; padding: 48px 40px; }
    .header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 40px; }
    .brand { font-size: 22px; font-weight: 700; color: #4f46e5; }
    .brand-sub { font-size: 12px; color: #6b7280; margin-top: 2px; }
    .doc-label { background: #eef2ff; color: #4f46e5; font-size: 11px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; padding: 6px 12px; border-radius: 4px; }
    .meta { display: flex; gap: 48px; margin-bottom: 36px; }
    .meta-block h4 { font-size: 10px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; color: #9ca3af; margin-bottom: 6px; }
    .meta-block p { font-size: 14px; color: #374151; line-height: 1.6; }
    .divider { height: 1px; background: #e5e7eb; margin: 28px 0; }
    h2 { font-size: 13px; font-weight: 700; letter-spacing: 0.5px; text-transform: uppercase; color: #4f46e5; margin-bottom: 12px; }
    .scope { font-size: 14px; color: #374151; line-height: 1.8; background: #f9fafb; border-left: 3px solid #4f46e5; padding: 16px 20px; border-radius: 0 6px 6px 0; }
    .deliverables { list-style: none; margin-top: 0; }
    .deliverables li { font-size: 14px; color: #374151; padding: 8px 0 8px 20px; border-bottom: 1px solid #f3f4f6; position: relative; }
    .deliverables li::before { content: '✓'; position: absolute; left: 0; color: #4f46e5; font-weight: 700; }
    .details-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
    .detail-item { background: #f9fafb; border-radius: 8px; padding: 16px; }
    .detail-item label { font-size: 10px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; color: #9ca3af; display: block; margin-bottom: 4px; }
    .detail-item span { font-size: 15px; font-weight: 600; color: #111827; }
    .services-table { width: 100%; border-collapse: collapse; }
    .services-table th { font-size: 10px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; color: #9ca3af; text-align: left; padding: 10px 0; border-bottom: 2px solid #e5e7eb; }
    .services-table th:last-child { text-align: right; }
    .services-table td { font-size: 14px; color: #374151; padding: 12px 0; border-bottom: 1px solid #f3f4f6; }
    .services-table td:last-child { text-align: right; font-weight: 600; }
    .total-row { display: flex; justify-content: flex-end; margin-top: 16px; }
    .total-box { background: #4f46e5; color: #fff; border-radius: 8px; padding: 12px 24px; text-align: right; }
    .total-box .label { font-size: 11px; opacity: 0.8; letter-spacing: 1px; text-transform: uppercase; }
    .total-box .amount { font-size: 22px; font-weight: 700; margin-top: 2px; }
    .validity { background: #fefce8; border: 1px solid #fde68a; border-radius: 6px; padding: 12px 16px; font-size: 13px; color: #92400e; margin-top: 24px; }
    .footer { margin-top: 48px; padding-top: 24px; border-top: 1px solid #e5e7eb; display: flex; justify-content: space-between; font-size: 12px; color: #9ca3af; }
  </style>
</head>
<body>
  <div class="accent-bar"></div>
  <div class="container">
    <div class="header">
      <div>
        <div class="brand">{{freelancer.company}}</div>
        <div class="brand-sub">{{freelancer.email}} · {{freelancer.phone}}</div>
      </div>
      <div class="doc-label">Project Proposal</div>
    </div>

    <div class="meta">
      <div class="meta-block">
        <h4>Prepared for</h4>
        <p><strong>{{client.name}}</strong><br />{{client.company}}<br />{{client.email}}<br />{{client.address}}</p>
      </div>
      <div class="meta-block">
        <h4>Prepared by</h4>
        <p><strong>{{freelancer.name}}</strong><br />{{freelancer.company}}<br />{{freelancer.address}}</p>
      </div>
      <div class="meta-block">
        <h4>Project</h4>
        <p><strong>{{project.name}}</strong><br />Start: {{project.startDate}}</p>
      </div>
    </div>

    <div class="divider"></div>

    <h2>Scope of Work</h2>
    <div class="scope">{{scopeOfWork}}</div>

    <div class="divider"></div>

    <h2>Deliverables</h2>
    <ul class="deliverables">
      {{#each deliverables}}
      <li>{{this}}</li>
      {{/each}}
    </ul>

    <div class="divider"></div>

    <div class="details-grid">
      <div class="detail-item">
        <label>Timeline</label>
        <span>{{timeline}}</span>
      </div>
      <div class="detail-item">
        <label>Valid Until</label>
        <span>{{validUntil}}</span>
      </div>
    </div>

    <div class="divider"></div>

    <h2>Investment</h2>
    <table class="services-table">
      <thead>
        <tr>
          <th>Service</th>
          <th style="text-align:right">Price</th>
        </tr>
      </thead>
      <tbody>
        {{#each services}}
        <tr>
          <td>{{description}}</td>
          <td>{{price}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
    <div class="total-row">
      <div class="total-box">
        <div class="label">Total Investment</div>
        <div class="amount">{{totalPrice}}</div>
      </div>
    </div>

    <div class="validity">
      ⏳ This proposal is valid until <strong>{{validUntil}}</strong>. To proceed, please reply to confirm acceptance.
    </div>

    <div class="footer">
      <span>{{freelancer.company}} · {{freelancer.address}}</span>
      <span>Prepared for {{client.company}}</span>
    </div>
  </div>
</body>
</html>
