<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Helvetica Neue', Arial, sans-serif; color: #1a1a2e; background: #fff; }
    .accent-bar { height: 6px; background: linear-gradient(90deg, #4f46e5, #818cf8); }
    .container { max-width: 780px; margin: 0 auto; padding: 48px 40px; }
    .header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 40px; }
    .brand { font-size: 22px; font-weight: 700; color: #4f46e5; }
    .brand-sub { font-size: 12px; color: #6b7280; margin-top: 2px; }
    .doc-label { background: #eef2ff; color: #4f46e5; font-size: 11px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; padding: 6px 12px; border-radius: 4px; }
    .paid-stamp { text-align: center; margin: 32px 0; padding: 28px; border: 4px solid #16a34a; border-radius: 12px; display: inline-block; width: 100%; }
    .paid-word { font-size: 56px; font-weight: 900; color: #16a34a; letter-spacing: 8px; opacity: 0.9; }
    .paid-amount { font-size: 28px; font-weight: 700; color: #111827; margin-top: 4px; }
    .paid-note { font-size: 13px; color: #6b7280; margin-top: 6px; }
    .details-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; margin: 32px 0; }
    .detail { background: #f9fafb; border-radius: 8px; padding: 16px; }
    .detail label { font-size: 10px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; color: #9ca3af; display: block; margin-bottom: 4px; }
    .detail span { font-size: 14px; font-weight: 600; color: #111827; }
    .divider { height: 1px; background: #e5e7eb; margin: 24px 0; }
    .parties { display: flex; justify-content: space-between; }
    .party h4 { font-size: 10px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; color: #9ca3af; margin-bottom: 8px; }
    .party p { font-size: 13px; color: #374151; line-height: 1.7; }
    .confirmation { background: #f0fdf4; border: 1px solid #86efac; border-radius: 8px; padding: 16px 20px; margin-top: 28px; font-size: 13.5px; color: #166534; line-height: 1.7; }
    .footer { margin-top: 40px; padding-top: 20px; border-top: 1px solid #e5e7eb; display: flex; justify-content: space-between; font-size: 11px; color: #9ca3af; }
  </style>
</head>
<body>
  <div class="accent-bar"></div>
  <div class="container">
    <div class="header">
      <div>
        <div class="brand">{{freelancer.company}}</div>
        <div class="brand-sub">{{freelancer.email}} · {{freelancer.phone}}</div>
      </div>
      <div class="doc-label">Payment Receipt</div>
    </div>

    <div class="paid-stamp">
      <div class="paid-word">PAID</div>
      <div class="paid-amount">{{amountPaid}}</div>
      <div class="paid-note">Payment confirmed for {{project.name}}</div>
    </div>

    <div class="details-grid">
      <div class="detail">
        <label>Receipt No.</label>
        <span>{{receiptNumber}}</span>
      </div>
      <div class="detail">
        <label>Payment Date</label>
        <span>{{paymentDate}}</span>
      </div>
      <div class="detail">
        <label>Payment Method</label>
        <span>{{paymentMethod}}</span>
      </div>
    </div>

    <div class="divider"></div>

    <div class="parties">
      <div class="party">
        <h4>Received From</h4>
        <p><strong>{{client.name}}</strong><br />{{client.company}}<br />{{client.address}}<br />{{client.email}}</p>
      </div>
      <div class="party" style="text-align:right">
        <h4>Received By</h4>
        <p><strong>{{freelancer.name}}</strong><br />{{freelancer.company}}<br />{{freelancer.address}}</p>
      </div>
    </div>

    <div class="confirmation">
      ✅ This receipt confirms that <strong>{{amountPaid}}</strong> has been received from <strong>{{client.company}}</strong> on <strong>{{paymentDate}}</strong> via <strong>{{paymentMethod}}</strong> in full payment for <strong>{{project.name}}</strong> (Invoice Ref: <strong>{{invoiceReference}}</strong>).
    </div>

    <div class="footer">
      <span>{{freelancer.company}} · {{receiptNumber}}</span>
      <span>Thank you for your payment!</span>
    </div>
  </div>
</body>
</html>
